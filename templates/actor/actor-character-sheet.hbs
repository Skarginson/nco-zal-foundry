<form class="{{cssClass}} {{actor.type}} flexcol" autocomplete="off">

  {{!-- En-tête --}}
  <header class="sheet-header flexrow">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" data-action="editImage" title="{{actor.name}}" height="100" width="68"/>
    <div class="header-fields flexcol">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'NCO.Actor.Name'}}"/>
      </h1>
      <button type="button" class="btn-open-roll nco-roll-btn" data-action="openRoll">
        <i class="fas fa-dice-d6"></i>
        {{localize 'NCO.Roll.RollDice'}}
      </button>
    </div>
  </header>

  {{!-- Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="trademarks" data-action="changeTab">{{localize 'NCO.Tab.Trademarks'}}</a>
    <a class="item" data-tab="etat"       data-action="changeTab">{{localize 'NCO.Tab.Etat'}}</a>
    <a class="item" data-tab="equipement" data-action="changeTab">{{localize 'NCO.Tab.Equipement'}}</a>
  </nav>

  <section class="sheet-body">

    {{!-- ===== Tab Trademarks ===== --}}
    <div class="tab trademarks flexcol" data-group="primary" data-tab="trademarks">

      {{#if editable}}
      <div class="tab-section-header">
        <a class="item-create tm-create" data-type="trademark" data-action="itemCreate"
           title="{{localize 'NCO.Item.AddTrademark'}}">
          <i class="fas fa-plus"></i> {{localize 'NCO.Item.AddTrademark'}}
        </a>
      </div>
      {{/if}}

      {{#each trademarks as |tm|}}
      <div class="trademark-block {{#if tm.system.active}}tm-is-active{{/if}}" data-item-id="{{tm._id}}">
        <div class="trademark-header flexrow">
          <button type="button" class="tm-toggle {{#if tm.system.active}}is-active{{/if}}"
                  data-action="toggleTrademark">
            <i class="fas fa-circle-dot tm-icon"></i>
            {{tm.name}}
          </button>
          {{#if @root.editable}}
          <a class="item-edit tm-edit" data-action="itemEdit" title="{{localize 'NCO.Item.Edit'}}">
            <i class="fas fa-pen"></i>
          </a>
          <a class="tm-delete" data-action="tmDelete" title="{{localize 'NCO.Item.Delete'}}">
            <i class="fas fa-times"></i>
          </a>
          {{/if}}
        </div>
        {{#if tm.edgesArray.length}}
        <div class="trademark-edges flexrow">
          {{#each tm.edgesArray as |edge|}}
          <button type="button"
                  class="edge-toggle {{#if edge.active}}is-active{{/if}} {{#unless edge.usable}}edge-locked{{/unless}}"
                  data-field="{{edge.field}}"
                  data-action="toggleEdge">
            {{edge.value}}
          </button>
          {{/each}}
        </div>
        {{/if}}
      </div>
      {{/each}}

    </div>

    {{!-- ===== Tab État ===== --}}
    <div class="tab etat flexcol" data-group="primary" data-tab="etat">

      {{!-- HITS : 3 cases cliquables --}}
      <div class="char-block">
        <h4 class="block-title">{{localize 'NCO.Actor.Hits'}}</h4>
        <div class="pip-row flexrow">
          {{#each hitBoxes as |box|}}
          <span class="pip hit-pip {{#if box.filled}}pip-on{{/if}}"
                data-index="{{box.index}}"
                data-action="pipClick"
                data-field="system.hits.value"
                data-max="3"></span>
          {{/each}}
        </div>
      </div>

      {{!-- CONDITIONS : 6 cases --}}
      <div class="char-block">
        <h4 class="block-title">{{localize 'NCO.Actor.Conditions'}}</h4>
        <div class="conditions-grid">
          <label class="cond-label">
            <input type="checkbox" name="system.conditions.angry" {{#if system.conditions.angry}}checked{{/if}}/>
            {{localize 'NCO.Condition.Angry'}}
          </label>
          <label class="cond-label">
            <input type="checkbox" name="system.conditions.dazed" {{#if system.conditions.dazed}}checked{{/if}}/>
            {{localize 'NCO.Condition.Dazed'}}
          </label>
          <label class="cond-label">
            <input type="checkbox" name="system.conditions.exhausted" {{#if system.conditions.exhausted}}checked{{/if}}/>
            {{localize 'NCO.Condition.Exhausted'}}
          </label>
          <label class="cond-label">
            <input type="checkbox" name="system.conditions.scared" {{#if system.conditions.scared}}checked{{/if}}/>
            {{localize 'NCO.Condition.Scared'}}
          </label>
          <label class="cond-label">
            <input type="checkbox" name="system.conditions.restrained" {{#if system.conditions.restrained}}checked{{/if}}/>
            {{localize 'NCO.Condition.Restrained'}}
          </label>
          <label class="cond-label">
            <input type="checkbox" name="system.conditions.weakened" {{#if system.conditions.weakened}}checked{{/if}}/>
            {{localize 'NCO.Condition.Weakened'}}
          </label>
        </div>
      </div>

      {{!-- STUNT POINTS : 3 cases cliquables --}}
      <div class="char-block">
        <h4 class="block-title">{{localize 'NCO.Actor.StuntPoints'}}</h4>
        <div class="pip-row flexrow">
          {{#each stuntBoxes as |box|}}
          <span class="pip stunt-pip {{#if box.filled}}pip-on{{/if}}"
                data-index="{{box.index}}"
                data-action="pipClick"
                data-field="system.stunt_points.value"
                data-max="3"></span>
          {{/each}}
        </div>
      </div>

      {{!-- TRAUMAS : 8 champs en 2 colonnes --}}
      <div class="char-block">
        <h4 class="block-title">{{localize 'NCO.Actor.Traumas'}}</h4>
        <div class="trauma-grid">
          <input type="text" name="system.trauma1" value="{{system.trauma1}}" placeholder="—"/>
          <input type="text" name="system.trauma2" value="{{system.trauma2}}" placeholder="—"/>
          <input type="text" name="system.trauma3" value="{{system.trauma3}}" placeholder="—"/>
          <input type="text" name="system.trauma4" value="{{system.trauma4}}" placeholder="—"/>
          <input type="text" name="system.trauma5" value="{{system.trauma5}}" placeholder="—"/>
          <input type="text" name="system.trauma6" value="{{system.trauma6}}" placeholder="—"/>
          <input type="text" name="system.trauma7" value="{{system.trauma7}}" placeholder="—"/>
          <input type="text" name="system.trauma8" value="{{system.trauma8}}" placeholder="—"/>
        </div>
      </div>

      {{!-- FLAWS --}}
      <div class="char-block">
        <h4 class="block-title">{{localize 'NCO.Actor.Flaws'}}</h4>
        <div class="trauma-grid">
          <input type="text" name="system.flaw1" value="{{system.flaw1}}" placeholder="—"/>
          <input type="text" name="system.flaw2" value="{{system.flaw2}}" placeholder="—"/>
        </div>
      </div>

    </div>

    {{!-- ===== Tab Équipement & XP ===== --}}
    <div class="tab equipement flexcol" data-group="primary" data-tab="equipement">

      {{!-- GEAR + STASH --}}
      <div class="char-block">
        <div class="block-header flexrow">
          <h4 class="block-title">{{localize 'NCO.Item.Gear'}}</h4>
          {{#if editable}}
          <a class="item-create" data-type="gear" data-action="itemCreate"
             title="{{localize 'NCO.Item.AddGear'}}">
            <i class="fas fa-plus"></i>
          </a>
          {{/if}}
        </div>
        <ul class="gear-list">
          {{#each gear as |item|}}
          <li class="gear-item flexrow" data-item-id="{{item._id}}">
            <span class="gear-name {{#if (eq item.system.gear_type 'special')}}gear-special{{/if}}">
              {{item.name}}
            </span>
            {{#if (eq item.system.gear_type 'special')}}
            <div class="gear-tags flexrow">
              {{#each item.tagsArray as |tag|}}
              <button type="button"
                      class="edge-toggle {{#if tag.active}}is-active{{/if}}"
                      data-field="{{tag.field}}"
                      data-action="toggleGearTag">
                {{tag.value}}
              </button>
              {{/each}}
            </div>
            {{/if}}
            {{#if @root.editable}}
            <div class="item-controls flexrow">
              <a class="item-edit" data-action="itemEdit"
                 title="{{localize 'NCO.Item.Edit'}}"><i class="fas fa-edit"></i></a>
              <a class="item-delete" data-action="itemDelete"
                 title="{{localize 'NCO.Item.Delete'}}"><i class="fas fa-trash"></i></a>
            </div>
            {{/if}}
          </li>
          {{else}}
          <li class="gear-empty">{{localize 'NCO.Item.EmptyGear'}}</li>
          {{/each}}
        </ul>
        <div class="stash-row flexrow">
          <span class="stash-label">{{localize 'NCO.Actor.Stash'}}</span>
          <div class="pip-row flexrow">
            {{#each stashBoxes as |box|}}
            <span class="pip stash-pip {{#if box.filled}}pip-on{{/if}}"
                  data-index="{{box.index}}"
                  data-action="pipClick"
                  data-field="system.stash.value"
                  data-max="5"></span>
            {{/each}}
          </div>
        </div>
      </div>

      {{!-- DRIVE --}}
      <div class="char-block">
        <h4 class="block-title">{{localize 'NCO.Actor.Drive'}}</h4>
        <input type="text" name="system.drive" value="{{system.drive}}" class="drive-input"
               placeholder="{{localize 'NCO.Actor.DrivePlaceholder'}}"/>
        <div class="pip-row flexrow" style="margin-top: 6px;">
          {{#each driveBoxes as |box|}}
          <span class="pip drive-pip {{#if box.filled}}pip-on{{/if}}"
                data-index="{{box.index}}"
                data-action="pipClick"
                data-field="system.drive_track.value"
                data-max="9"></span>
          {{/each}}
        </div>
      </div>

      {{!-- XP --}}
      <div class="char-block">
        <h4 class="block-title">{{localize 'NCO.Actor.XP'}}</h4>
        <div class="xp-track flexrow">
          {{#each xpGroups as |group gi|}}
          {{#if gi}}<span class="xp-sep">|</span>{{/if}}
          {{#each group as |box|}}
          <span class="pip xp-pip {{#if box.filled}}pip-on{{/if}}"
                data-index="{{box.index}}"
                data-action="pipClick"
                data-field="system.xp.value"
                data-max="15"></span>
          {{/each}}
          {{/each}}
        </div>
      </div>

    </div>

  </section>

</form>
