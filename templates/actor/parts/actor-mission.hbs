{{!-- Onglet Mission — Zalozhniy Quartet uniquement --}}

{{!-- Jauge d'Exposition --}}
<div class="exposure-section">
  <h3 class="section-title">{{localize 'NCO.Zalozhniy.Exposure'}}</h3>
  <div class="exposure-track flexrow">
    {{#each exposureSteps as |step i|}}
    <div class="exposure-pip {{#if step.filled}}pip-filled{{/if}} {{#if step.critical}}pip-critical{{/if}}"
         data-index="{{i}}"
         title="{{i}}">
      {{i}}
    </div>
    {{/each}}
    <div class="exposure-inputs flexrow">
      <input type="number" name="system.exposure.value" value="{{system.exposure.value}}" min="0" max="5" data-dtype="Number" class="exposure-input"/>
      <span class="exposure-label">/5</span>
    </div>
  </div>
  {{#if exposureCritical}}
  <p class="exposure-warning">
    <i class="fas fa-exclamation-triangle"></i> {{localize 'NCO.Zalozhniy.ExposureCritical'}}
  </p>
  {{/if}}
</div>

<div class="mission-divider"></div>

{{!-- Assets --}}
<div class="items-section">
  <div class="items-header flexrow">
    <h3>{{localize 'NCO.Item.Asset'}}</h3>
    {{#if editable}}
    <a class="item-create" data-type="asset" title="{{localize 'NCO.Item.AddAsset'}}">
      <i class="fas fa-plus"></i>
    </a>
    {{/if}}
  </div>
  <ul class="items-list">
    {{#each assets as |item|}}
    <li class="item flexrow {{#if item.system.burned}}asset-burned{{/if}}" data-item-id="{{item._id}}">
      <img src="{{item.img}}" class="item-image" width="24" height="24"/>
      <span class="item-name {{#if item.system.burned}}text-burned{{/if}}">{{item.name}}</span>
      <span class="asset-type-badge">{{localize (concat 'NCO.Asset.Type.' item.system.type)}}</span>
      <span class="asset-reliability">
        {{#each (times item.system.reliability) as |n|}}●{{/each}}{{#each (times (subtract 3 item.system.reliability)) as |n|}}○{{/each}}
      </span>
      {{#if @root.editable}}
      <div class="item-controls flexrow">
        <a class="item-edit"><i class="fas fa-edit"></i></a>
        <a class="item-delete"><i class="fas fa-trash"></i></a>
      </div>
      {{/if}}
    </li>
    {{else}}
    <li class="item-empty">{{localize 'NCO.Item.EmptyAsset'}}</li>
    {{/each}}
  </ul>
</div>

{{!-- Threats --}}
<div class="items-section">
  <div class="items-header flexrow">
    <h3>{{localize 'NCO.Item.Threat'}}</h3>
    {{#if editable}}
    <a class="item-create" data-type="threat" title="{{localize 'NCO.Item.AddThreat'}}">
      <i class="fas fa-plus"></i>
    </a>
    {{/if}}
  </div>
  <ul class="items-list">
    {{#each threats as |item|}}
    <li class="item threat-item flexrow" data-item-id="{{item._id}}">
      <img src="{{item.img}}" class="item-image" width="24" height="24"/>
      <span class="item-name">{{item.name}}</span>
      <span class="threat-dd">{{item.system.danger_dice_pool}} DD</span>
      <span class="threat-exposure">⚠ {{item.system.exposure_threshold}}</span>
      {{#if @root.editable}}
      <div class="item-controls flexrow">
        <a class="item-edit"><i class="fas fa-edit"></i></a>
        <a class="item-delete"><i class="fas fa-trash"></i></a>
      </div>
      {{/if}}
    </li>
    {{else}}
    <li class="item-empty">{{localize 'NCO.Item.EmptyThreat'}}</li>
    {{/each}}
  </ul>
</div>
