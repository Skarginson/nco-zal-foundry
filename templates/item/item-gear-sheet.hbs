<form class="{{cssClass}} item flexcol" autocomplete="off">
  <header class="sheet-header flexrow">
    <img class="item-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" width="60" height="60"/>
    <div class="header-fields flexcol">
      <h1><input name="name" type="text" value="{{item.name}}" placeholder="{{localize 'NCO.Item.NamePlaceholder'}}"/></h1>
    </div>
  </header>

  <section class="sheet-body flexcol" style="padding: 12px 16px; gap: 10px; overflow-y: auto;">

    {{!-- Type --}}
    <div class="form-group">
      <label style="font-size:0.72em; font-weight:700; text-transform:uppercase; color:var(--nco-text-muted);">
        {{localize 'NCO.Gear.Type'}}
      </label>
      <select name="system.gear_type">
        <option value="basic"   {{#if (eq system.gear_type 'basic')}}selected{{/if}}>{{localize 'NCO.Gear.TypeBasic'}}</option>
        <option value="special" {{#if (eq system.gear_type 'special')}}selected{{/if}}>{{localize 'NCO.Gear.TypeSpecial'}}</option>
      </select>
    </div>

    {{!-- Tags (special uniquement) --}}
    {{#if (eq system.gear_type 'special')}}
    <div class="form-group">
      <label style="font-size:0.72em; font-weight:700; text-transform:uppercase; color:var(--nco-text-muted);">
        {{localize 'NCO.Gear.Tags'}}
      </label>
      <div class="flexrow" style="gap:6px; align-items:center; margin-bottom:4px;">
        <span style="color:var(--nco-primary); font-weight:700; flex-shrink:0;">+</span>
        <input type="text" name="system.tag1" value="{{system.tag1}}" placeholder="{{localize 'NCO.Gear.TagPlaceholder'}}" style="flex:1;"/>
      </div>
      <div class="flexrow" style="gap:6px; align-items:center; margin-bottom:4px;">
        <span style="color:var(--nco-primary); font-weight:700; flex-shrink:0;">+</span>
        <input type="text" name="system.tag2" value="{{system.tag2}}" placeholder="{{localize 'NCO.Gear.TagPlaceholder'}}" style="flex:1;"/>
      </div>
      <div class="flexrow" style="gap:6px; align-items:center; margin-bottom:4px;">
        <span style="color:var(--nco-primary); font-weight:700; flex-shrink:0;">+</span>
        <input type="text" name="system.tag3" value="{{system.tag3}}" placeholder="{{localize 'NCO.Gear.TagPlaceholder'}}" style="flex:1;"/>
      </div>
      <div class="flexrow" style="gap:6px; align-items:center; margin-bottom:4px;">
        <span style="color:var(--nco-primary); font-weight:700; flex-shrink:0;">+</span>
        <input type="text" name="system.tag4" value="{{system.tag4}}" placeholder="{{localize 'NCO.Gear.TagPlaceholder'}}" style="flex:1;"/>
      </div>
      <div class="flexrow" style="gap:6px; align-items:center; margin-bottom:4px;">
        <span style="color:var(--nco-primary); font-weight:700; flex-shrink:0;">+</span>
        <input type="text" name="system.tag5" value="{{system.tag5}}" placeholder="{{localize 'NCO.Gear.TagPlaceholder'}}" style="flex:1;"/>
      </div>
    </div>
    {{/if}}

  </section>
</form>
