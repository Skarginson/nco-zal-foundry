<section class="{{cssClass}} flexcol" data-application-part="main">
  <header class="sheet-header flexrow">
    <div class="header-fields flexcol">
      <h1 class="charname">
        <input name="name" type="text" value="{{item.name}}"
               placeholder="{{localize 'NCO.Trademark.NamePlaceholder'}}"/>
      </h1>
    </div>
  </header>

  <div class="sheet-body flexcol" style="padding: 12px 16px; gap: 6px; overflow-y: auto;">

    <div class="form-group">
      <label style="font-size:0.72em; font-weight:700; text-transform:uppercase; color:var(--nco-text-muted);">Edges</label>
    </div>

    <div class="flexrow" style="gap:6px; align-items:center;">
      <span style="color:var(--nco-text-muted); font-weight:700; flex-shrink:0;">+</span>
      <input type="text" name="system.edge1" value="{{system.edge1}}"
             placeholder="{{localize 'NCO.Trademark.EdgePlaceholder'}}" style="flex:1;"/>
    </div>
    <div class="flexrow" style="gap:6px; align-items:center;">
      <span style="color:var(--nco-text-muted); font-weight:700; flex-shrink:0;">+</span>
      <input type="text" name="system.edge2" value="{{system.edge2}}"
             placeholder="{{localize 'NCO.Trademark.EdgePlaceholder'}}" style="flex:1;"/>
    </div>
    <div class="flexrow" style="gap:6px; align-items:center;">
      <span style="color:var(--nco-text-muted); font-weight:700; flex-shrink:0;">+</span>
      <input type="text" name="system.edge3" value="{{system.edge3}}"
             placeholder="{{localize 'NCO.Trademark.EdgePlaceholder'}}" style="flex:1;"/>
    </div>
    <div class="flexrow" style="gap:6px; align-items:center;">
      <span style="color:var(--nco-text-muted); font-weight:700; flex-shrink:0;">+</span>
      <input type="text" name="system.edge4" value="{{system.edge4}}"
             placeholder="{{localize 'NCO.Trademark.EdgePlaceholder'}}" style="flex:1;"/>
    </div>
    <div class="flexrow" style="gap:6px; align-items:center;">
      <span style="color:var(--nco-text-muted); font-weight:700; flex-shrink:0;">+</span>
      <input type="text" name="system.edge5" value="{{system.edge5}}"
             placeholder="{{localize 'NCO.Trademark.EdgePlaceholder'}}" style="flex:1;"/>
    </div>

  </div>
</section>
